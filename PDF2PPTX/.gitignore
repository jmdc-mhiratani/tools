# ============================================
# PDF2PPTX (Rust + pdfium)
# OS / IDE / Claude 系の共通設定はルート .gitignore 参照
# ============================================

# --- Rust / Cargo ビルド成果物 ---
/target/
**/*.rs.bk
*.pdb

# Cargo.lock はバイナリプロジェクトのため追跡する
# （ライブラリ化する場合のみコメントアウトを外す）
# Cargo.lock

# --- 配布バイナリ ---
dist/
*.exe

# --- pdfium 外部 SDK / DLL（ローカル配置、再配布できないため非追跡）---
# 利用者は別途 pdfium をダウンロードする運用
pdfium.dll
lib/

# --- アーカイブ（旧資産・参考用、配布対象外）---
archive/

# --- テスト出力 ---
tests/output/
tests/tmp/
*.snap.new
