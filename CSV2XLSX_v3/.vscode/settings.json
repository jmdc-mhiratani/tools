{
  // ========================================
  // CSV2XLSX_v3 сЃЌсЃГсѓИсѓДсѓ»сЃѕУеГт«џ (PySide6уЅѕ)
  // ========================================
  // GitHub Copilot УеГт«џ
  "github.copilot.chat.codeGeneration.instructions": [
    {
      "file": "../.github/copilot-instructions.md"
    },
    {
      "file": "../.github/instructions/python.instructions.md"
    },
    {
      "file": "CLAUDE.md"
    }
  ],
  // Python УеГт«џ
  "python.defaultInterpreterPath": "${workspaceFolder}/.venv/Scripts/python.exe",
  "python.formatting.provider": "black",
  // Pylance тъІсЃЂсѓДсЃЃсѓ»УеГт«џ
  "python.analysis.typeCheckingMode": "basic",
  "python.analysis.diagnosticMode": "workspace",
  "python.analysis.useLibraryCodeForTypes": true,
  "python.analysis.autoImportCompletions": true,
  "python.analysis.exclude": [
    "**/build/**",
    "**/dist/**",
    "**/.venv/**",
    "**/__pycache__/**"
  ],
  "[python]": {
    "editor.defaultFormatter": "charliermarsh.ruff",
    "editor.formatOnSave": true,
    "editor.codeActionsOnSave": {
      "source.organizeImports.ruff": "explicit",
      "source.fixAll.ruff": "explicit"
    }
  },
  // Ruff сЃфсЃ│сѓ┐сЃ╝УеГт«џ
  "ruff.enable": true,
  "ruff.lint.run": "onSave",
  // Mypy тъІсЃЂсѓДсЃЃсѓ»№╝ѕpyproject.tomlсЂДУеГт«џсђЂсѓ│сЃъсЃ│сЃЅсЃЕсѓцсЃ│сЂДт«ЪУАїТјетЦе№╝Ѕ
  "python.linting.mypyEnabled": false,
  // Pytest УеГт«џ
  "python.testing.pytestEnabled": true,
  "python.testing.unittestEnabled": false,
  "python.testing.pytestArgs": [
    "tests",
    "-v"
  ],
  // сѓесЃЄсѓБсѓ┐УеГт«џ
  "editor.formatOnSave": true,
  "editor.rulers": [
    88,
    120
  ],
  "editor.tabSize": 4,
  "editor.insertSpaces": true,
  "editor.trimAutoWhitespace": true,
  "files.trimTrailingWhitespace": true,
  "files.insertFinalNewline": true,
  "files.trimFinalNewlines": true,
  // сЃЋсѓАсѓцсЃФжЎцтцќУеГт«џ
  "files.exclude": {
    "**/__pycache__": true,
    "**/*.pyc": true,
    "**/*.pyo": true,
    "**/.pytest_cache": true,
    "**/.mypy_cache": true,
    "**/.ruff_cache": true,
    "**/.venv": false,
    "**/build": true,
    "**/dist": true,
    "**/*.egg-info": true
  },
  "search.exclude": {
    "**/__pycache__": true,
    "**/*.pyc": true,
    "**/.pytest_cache": true,
    "**/.mypy_cache": true,
    "**/.ruff_cache": true,
    "**/build": true,
    "**/dist": true,
    "**/*.egg-info": true
  },
  // сѓ┐сЃ╝сЃЪсЃісЃФУеГт«џ
  "terminal.integrated.env.windows": {
    "PYTHONPATH": "${workspaceFolder}/src"
  },
  "git.ignoreLimitWarning": true
}
